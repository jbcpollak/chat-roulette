# Operator configuration for deploy/gcp/deploy.sh
#
# Copy this file to deploy.env (which is gitignored) and fill in your values:
#
#   cp deploy/gcp/deploy.env.example deploy/gcp/deploy.env
#
# deploy.sh sources deploy.env automatically. Anything here can also be set as a
# normal environment variable instead.

# --- Required ---
PROJECT_ID=your-gcp-project-id
DOMAIN=chat.example.com
ACME_EMAIL=you@example.com

# --- Optional overrides (defaults shown) ---
# REGION=us-central1
# ZONE=us-central1-a
# VM_NAME=chat-roulette
# MACHINE_TYPE=e2-small
# SQL_INSTANCE=chat-roulette-db
# SQL_TIER=db-f1-micro
# DB_NAME=chat-roulette
# DB_USER=chat_roulette
# AR_REPO=cloud-run
# DNS_MANAGED=1                 # set 0 to never touch Cloud DNS
# DISABLE_ONBOARDING_FLOW=false # set true to skip the member onboarding questionnaire
